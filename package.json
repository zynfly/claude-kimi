{
  "name": "kimicode-mcp",
  "version": "0.5.2",
  "description": "MCP bridge that lets Claude Code delegate tasks to the local kimicode CLI via the Agent Client Protocol (ACP).",
  "type": "module",
  "private": true,
  "bin": {
    "kimicode-mcp": "./src/server.js"
  },
  "scripts": {
    "start": "node src/server.js",
    "smoke": "node scripts/smoke.js",
    "test": "node --test --test-reporter=spec 'test/**/*.test.js'",
    "test:live": "KIMI_LIVE_TEST=1 node --test --test-reporter=spec test/live-acp.test.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.4"
  },
  "engines": {
    "node": ">=18"
  }
}
